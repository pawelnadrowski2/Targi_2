# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# Plik .env.local NIE powinien trafiać do repozytorium (dodaj go do .gitignore).

# Hasło domyślne pierwszego uruchomienia (admin może je zmienić w panelu)
VITE_DEFAULT_ADMIN_PASS=zmien-to-haslo

# Token superusera — tajny, tylko dla właściciela systemu
# Jeśli puste, rola SuperUser jest wyłączona
VITE_SUPERUSER_TOKEN=

# Klucz API Gemini (opcjonalny — bez niego działa tryb offline z szablonami)
# Pobierz na: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
